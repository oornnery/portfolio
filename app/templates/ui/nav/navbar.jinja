{#def current_path="" #}

<nav class="navbar fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur-md border-b border-border/50" data-navbar>
    <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="text-base sm:text-lg font-medium text-foreground tracking-tight hover:text-accent transition-colors" data-analytics-event="click" data-analytics-id="nav-logo" data-analytics-label="logo">
            {{ site_name }}
        </a>

        <button type="button" class="navbar-toggle inline-flex items-center p-2.5 justify-center text-foreground/60 rounded-lg md:hidden hover:bg-surface-2/50 hover:text-accent focus:outline-none focus:ring-2 focus:ring-border-hover" aria-expanded="false" data-nav-toggle data-analytics-event="click" data-analytics-id="nav-menu-toggle" data-analytics-label="menu toggle">
            <span class="sr-only">Open main menu</span>
            <svg class="w-5 h-5" data-nav-icon-open xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14" aria-hidden="true">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
            </svg>
            <svg class="hidden w-5 h-5" data-nav-icon-close xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <div class="hidden w-full md:!block md:w-auto" data-nav-menu>
            <ul class="flex flex-col mt-4 md:mt-0 md:flex-row md:space-x-1 lg:space-x-2 font-medium text-sm rounded-lg md:border-0 border border-border bg-background/95 md:bg-transparent p-4 md:p-0 items-center">
                {% for link in nav_links %}
                <li>
                    <a href="{{ link.href }}" class="block px-3 py-2 rounded-lg {{ 'text-foreground bg-surface-2/50' if current_path == link.href else 'text-foreground/60 hover:text-accent hover:bg-surface-2/30' }} transition-all" data-nav-link data-analytics-event="click" data-analytics-id="nav-{{ link.label | lower }}" data-analytics-label="{{ link.label }}">
                        {{ link.label }}
                    </a>
                </li>
                {% endfor %}
                <li class="flex items-center gap-1">
                    {# Dark/Light toggle #}
                    <button type="button" class="inline-flex items-center justify-center p-2 rounded-lg text-foreground/60 hover:text-accent hover:bg-surface-2/30 transition-all" data-theme-toggle aria-label="Toggle dark/light mode">
                        <svg class="w-5 h-5 hidden" data-theme-icon-light xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
                        <svg class="w-5 h-5" data-theme-icon-dark xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
                    </button>

                    {# Palette selector #}
                    <div class="relative" data-palette-selector>
                        <button type="button" class="inline-flex items-center justify-center p-2 rounded-lg text-foreground/60 hover:text-accent hover:bg-surface-2/30 transition-all" data-palette-trigger aria-label="Select color palette" aria-expanded="false">
                            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.15"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.15"/></svg>
                        </button>
                        <div class="hidden absolute right-0 top-full mt-2 w-44 rounded-lg border border-border bg-background/95 backdrop-blur-md shadow-lg py-1.5" data-palette-dropdown role="listbox" aria-label="Color palettes">
                            {% set palettes = [
                                ("default", "Default", "#7c7cff", "#7c3aed"),
                                ("ocean", "Ocean", "#14b8a6", "#0891b2"),
                                ("sunset", "Sunset", "#f97316", "#ef4444"),
                                ("rose", "Rose", "#f43f5e", "#ec4899"),
                                ("forest", "Forest", "#22c55e", "#10b981"),
                                ("mono", "Mono", "#a1a1aa", "#71717a"),
                            ] %}
                            {% for id, name, c1, c2 in palettes %}
                            <button type="button" role="option" data-palette-option="{{ id }}" class="palette-option w-full flex items-center gap-3 px-3 py-2 text-sm text-foreground/70 hover:bg-surface-2/50 hover:text-foreground transition-colors">
                                <span class="flex gap-0.5">
                                    <span class="w-3 h-3 rounded-full" style="background:{{ c1 }}"></span>
                                    <span class="w-3 h-3 rounded-full" style="background:{{ c2 }}"></span>
                                </span>
                                <span class="flex-1 text-left">{{ name }}</span>
                                <svg class="w-4 h-4 hidden" data-palette-check xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                            </button>
                            {% endfor %}
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</nav>
