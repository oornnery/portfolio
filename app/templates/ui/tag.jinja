{#def text="", variant="default", size="default", removable=False, href="" #}

{% set variants = {
    "default": "bg-gray-800 text-gray-300 border border-gray-700",
    "primary": "bg-gray-200 text-gray-900",
    "accent": "bg-accent/10 text-accent border border-accent/20",
    "secondary": "bg-accent-secondary/10 text-accent-glow border border-accent-secondary/20",
    "success": "bg-green-500/10 text-green-400 border border-green-500/20",
    "warning": "bg-orange-500/10 text-orange-400 border border-orange-500/20",
    "danger": "bg-red-500/10 text-red-400 border border-red-500/20",
    "outline": "bg-transparent text-gray-400 border border-gray-700 hover:text-blue-400 hover:border-blue-400/60"
} %}
{% set sizes = {"xs": "px-2 py-0.5 text-[10px]", "sm": "px-2.5 py-0.5 text-xs", "default": "px-3 py-1 text-xs"} %}
{% set cls = "inline-flex items-center gap-1 font-medium rounded-full " ~ variants[variant] ~ " " ~ sizes[size] %}
{% set link_hover = "transition-colors hover:text-blue-400 hover:border-blue-400/60 hover:bg-gray-800/80" %}

{% if href %}
<a href="{{ href }}" class="{{ cls }} {{ link_hover }}" {{ attrs.render() }}>{{ text or content }}</a>
{% else %}
<span class="{{ cls }}" {{ attrs.render() }}>{{ text or content }}</span>
{% endif %}
