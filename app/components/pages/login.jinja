{#def request, user=None, error="" #}
{#import "../layouts/base.jinja" as BaseLayout #}
{#import "../ui/button.jinja" as Button #}
{#import "../ui/input.jinja" as Input #}

<BaseLayout title="Login">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="w-full max-w-sm space-y-8">
            <div class="text-center">
                <h1 class="text-2xl font-bold text-white mb-2">Welcome Back</h1>
                <p class="text-gray-400">Sign in to your account</p>
            </div>

            {% if error %}
            <div class="bg-red-900/50 border border-red-800 text-red-200 px-4 py-3 rounded">
                {{ error }}
            </div>
            {% endif %}

            <form action="/api/v1/auth/login" method="post" class="space-y-6">
                <Input name="email" type="email" label="Email" placeholder="your@email.com" required />
                <Input name="password" type="password" label="Password" placeholder="••••••••" required />
                <Button type="submit" variant="primary" class="w-full">Sign In</Button>
            </form>

            <div class="relative">
                <div class="absolute inset-0 flex items-center">
                    <span class="w-full border-t border-gray-800"></span>
                </div>
                <div class="relative flex justify-center text-xs uppercase">
                    <span class="bg-black px-2 text-gray-500">Or continue with</span>
                </div>
            </div>

            <Button href="/api/v1/auth/github" variant="default" class="w-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                GitHub
            </Button>

            <p class="text-center text-sm text-gray-500">
                <a href="/" class="hover:text-white transition-colors">&larr; Back to home</a>
            </p>
        </div>
    </div>
</BaseLayout>
