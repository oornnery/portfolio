{#def request, user=None, posts=[], categories=[], current_category="" #}
{#import "../layouts/public.jinja" as PublicLayout #}
{#import "../blog/post-card.jinja" as PostCard #}
{#import "../ui/button.jinja" as Button #}
{#import "../ui/input.jinja" as Input #}

<PublicLayout request={{ request }} user={{ user }} title="Blog" current_page="blog">
    <div class="space-y-8">
        <header>
            <h1 class="text-3xl font-bold text-white mb-2">Blog</h1>
            <p class="text-gray-400">Thoughts, tutorials, and insights about technology and development.</p>
        </header>

        {# Filters #}
        <div class="space-y-4">
            <form hx-get="/blog" hx-target="#posts-grid" hx-trigger="input changed delay:300ms, submit" hx-swap="innerHTML" hx-push-url="false">
                <Input 
                    name="search" 
                    type="search" 
                    placeholder="Search posts..."
                />
            </form>
            
            {% if categories %}
            <div class="flex flex-wrap gap-2">
                <button 
                    hx-get="/blog" 
                    hx-target="#posts-grid" 
                    hx-swap="innerHTML"
                    hx-push-url="false"
                    class="px-3 py-1.5 text-sm rounded-lg border transition-colors {{ 'bg-gray-800 text-white border-gray-700' if not current_category else 'bg-transparent text-gray-400 border-gray-800 hover:bg-gray-800 hover:text-white' }}"
                >All</button>
                {% for cat in categories %}
                <button 
                    hx-get="{{ '/blog?category=' ~ cat }}"
                    hx-target="#posts-grid" 
                    hx-swap="innerHTML"
                    hx-push-url="false"
                    class="px-3 py-1.5 text-sm rounded-lg border transition-colors {{ 'bg-gray-800 text-white border-gray-700' if current_category == cat else 'bg-transparent text-gray-400 border-gray-800 hover:bg-gray-800 hover:text-white' }}"
                >{{ cat }}</button>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        {# Posts Grid #}
        <div id="posts-grid" class="space-y-4">
            {% for post in posts %}
            <PostCard post={{ post }} />
            {% else %}
            <div class="text-center py-12">
                <p class="text-gray-500">No posts found.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</PublicLayout>
