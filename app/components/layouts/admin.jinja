{#import "./base.jinja" as Base #}
{#import "../ui/navbar.jinja" as Navbar #}
{#def title="Admin", current_page="dashboard", user=None, request=None #}

<Base title={{ title }} current_page="admin">
    <Navbar user={{ user }} current_page="admin" />
    
    <div class="max-w-5xl mx-auto px-6 pt-20 pb-12">
        <div class="flex gap-8">
            <!-- Sidebar -->
            <aside class="w-48 shrink-0">
                <nav class="sticky top-24 space-y-1">
                    <a href="/admin" class="block px-3 py-2 text-sm {{ 'text-white bg-gray-800' if current_page == 'dashboard' else 'text-gray-400 hover:text-white hover:bg-gray-800' }} rounded transition-colors">
                        Dashboard
                    </a>
                    <a href="/admin/profile" class="block px-3 py-2 text-sm {{ 'text-white bg-gray-800' if current_page == 'profile' else 'text-gray-400 hover:text-white hover:bg-gray-800' }} rounded transition-colors">
                        Profile
                    </a>
                    <a href="/admin/projects" class="block px-3 py-2 text-sm {{ 'text-white bg-gray-800' if current_page == 'projects' else 'text-gray-400 hover:text-white hover:bg-gray-800' }} rounded transition-colors">
                        Projects
                    </a>
                    <a href="/admin/blog" class="block px-3 py-2 text-sm {{ 'text-white bg-gray-800' if current_page == 'blog' else 'text-gray-400 hover:text-white hover:bg-gray-800' }} rounded transition-colors">
                        Blog
                    </a>
                </nav>
            </aside>
            
            <!-- Main Content -->
            <main class="flex-1 min-w-0">
                {{ content }}
            </main>
        </div>
    </div>
</Base>
