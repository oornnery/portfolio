{#def profile #}
{#import "../ui/SocialButton.jinja" as SocialButton #}

<header class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8">
    {# Avatar #}
    <span class="relative flex shrink-0 overflow-hidden rounded-full size-24 sm:size-28" aria-hidden="true">
        <img class="aspect-square h-full w-full"
            alt="{{ profile.name if profile else 'Fabio Souza' }}'s profile picture"
            src="https://ui-avatars.com/api/?name={{ (profile.name if profile else 'Fabio Souza') | urlencode }}&background=1a1a1a&color=fff&size=128">
    </span>

    {# Info #}
    <div class="flex-1 text-center sm:text-left">
        <h1 class="text-2xl sm:text-3xl font-bold text-white mb-1">{{ profile.name if profile else 'Fabio Souza' }}</h1>
        <p class="text-sm sm:text-base text-gray-400 font-mono mb-1">
            {{ profile.short_bio if profile else 'Full-stack Developer' }}
        </p>
        <p class="text-xs sm:text-sm text-gray-500 font-mono mb-4">
            <a class="hover:underline"
                href="https://www.google.com/maps/search/{{ profile.location if profile else 'S&#227;o Paulo, Brazil' }}"
                target="_blank" rel="noopener noreferrer">
                {{ profile.location if profile else 'S&#227;o Paulo, Brazil' }}
            </a>
        </p>

        {# Social links #}
        <div class="flex flex-wrap justify-center sm:justify-start gap-2 mb-4" role="list" aria-label="Contact links">
            {% if profile %}
            {% if profile.email %}
            <SocialButton href="mailto:{{ profile.email }}" label="Email" icon="email" />{% endif %}
            {% if profile.github %}
            <SocialButton href={{ profile.github }} label="GitHub" icon="github" />{% endif %}
            {% if profile.linkedin %}
            <SocialButton href={{ profile.linkedin }} label="LinkedIn" icon="linkedin" />{% endif %}
            {% if profile.twitter %}
            <SocialButton href={{ profile.twitter }} label="X" icon="twitter" />{% endif %}
            {% else %}
            <SocialButton href="mailto:fabiohcsouza@outlook.com.br" label="Email" icon="email" />
            <SocialButton href="https://github.com/oornnery" label="GitHub" icon="github" />
            <SocialButton href="https://linkedin.com/in/fabiohcsouza" label="LinkedIn" icon="linkedin" />
            <SocialButton href="https://x.com/oornnery" label="X" icon="twitter" />
            {% endif %}
        </div>

        {# Resume link #}
        <a href="/about" class="inline-flex items-center text-sm text-gray-400 hover:text-white transition-colors">
            View full resume &rarr;
        </a>
    </div>
</header>