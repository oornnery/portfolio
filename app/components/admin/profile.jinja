{#def request, user, profile, title="Edit Profile" #}
{#import "../layouts/admin.jinja" as AdminLayout #}
{#import "../ui/input.jinja" as Input #}
{#import "../ui/button.jinja" as Button #}

<AdminLayout request={{ request }} user={{ user }} title={{ title }} current_page="profile">
    <div class="space-y-8">
        <header class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Edit Profile</h1>
                <p class="text-gray-400">Update your public profile information.</p>
            </div>
        </header>

        <form method="post" action="/admin/profile" class="space-y-8">
            {# Basic Info #}
            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Basic Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <Input name="name" label="Name" value={{ profile.name or '' }} required />
                    <Input name="location" label="Location" value={{ profile.location or '' }} />
                </div>
                <Input name="short_bio" type="textarea" label="Short Bio" value={{ profile.short_bio or '' }} rows="2" />
            </section>

            {# Contact Info #}
            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Contact</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <Input name="email" type="email" label="Email" value={{ profile.email or '' }} />
                    <Input name="phone" label="Phone" value={{ profile.phone or '' }} />
                    <Input name="website" type="url" label="Website" value={{ profile.website or '' }} />
                </div>
            </section>

            {# Social Links #}
            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Social Links</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <Input name="github" type="url" label="GitHub" value={{ profile.github or '' }} />
                    <Input name="linkedin" type="url" label="LinkedIn" value={{ profile.linkedin or '' }} />
                    <Input name="twitter" type="url" label="Twitter/X" value={{ profile.twitter or '' }} />
                </div>
            </section>

            {# About (Markdown) #}
            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">About</h2>
                <Input name="about_markdown" type="textarea" label="About (Markdown)" value={{ profile.about_markdown or '' }} rows="6" />
            </section>

            {# JSON Fields #}
            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Work Experience</h2>
                <Input 
                    name="work_experience_json" 
                    type="textarea" 
                    label="Work Experience (JSON)" 
                    value={{ profile.work_experience | tojson if profile.work_experience else '[]' }} 
                    rows="4" 
                />
                <p class="text-xs text-gray-500">Format: [{"title": "...", "company": "...", "location": "...", "start_date": "...", "end_date": "...", "description": "..."}]</p>
            </section>

            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Education</h2>
                <Input 
                    name="education_json" 
                    type="textarea" 
                    label="Education (JSON)" 
                    value={{ profile.education | tojson if profile.education else '[]' }} 
                    rows="4" 
                />
                <p class="text-xs text-gray-500">Format: [{"school": "...", "degree": "...", "start_date": "...", "end_date": "..."}]</p>
            </section>

            <section class="space-y-4">
                <h2 class="text-xl font-semibold text-white">Skills</h2>
                <Input 
                    name="skills_json" 
                    type="textarea" 
                    label="Skills (JSON array)" 
                    value={{ profile.skills | tojson if profile.skills else '[]' }} 
                    rows="2" 
                />
                <p class="text-xs text-gray-500">Format: ["Python", "JavaScript", "Docker", ...]</p>
            </section>

            <div class="flex justify-end">
                <Button type="submit" variant="primary">Save Changes</Button>
            </div>
        </form>
    </div>
</AdminLayout>
