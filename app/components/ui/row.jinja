{#def gap="2", wrap=False, justify="start", align="center", class_name="" #}

{% set base = "flex" %}
{% set gaps = {
    "1": "gap-1",
    "1.5": "gap-1.5",
    "2": "gap-2",
    "3": "gap-3",
    "4": "gap-4",
    "6": "gap-6",
    "8": "gap-8"
} %}
{% set justifies = {
    "start": "justify-start",
    "center": "justify-center",
    "end": "justify-end",
    "between": "justify-between"
} %}
{% set aligns = {
    "start": "items-start",
    "center": "items-center",
    "end": "items-end",
    "stretch": "items-stretch",
    "baseline": "items-baseline"
} %}
{% set cls = (base ~ " " ~ ("flex-wrap " if wrap else "") ~ gaps.get(gap, "gap-" ~ gap) ~ " " ~ justifies.get(justify, "") ~ " " ~ aligns.get(align, "") ~ " " ~ class_name).strip() %}

<div class="{{ cls }}" {{ attrs.render() }}>
    {{ content }}
</div>
