# ===========================================
# Environment Configuration
# ===========================================

# Environment mode: development | production
ENV=development

# ===========================================
# Database
# ===========================================

# SQLite for development
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/portfolio_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change_this_strong_password
# POSTGRES_DB=portfolio_db

# ===========================================
# Security (REQUIRED in production)
# ===========================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Allowed hosts (comma-separated for multiple)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Force HTTPS redirect (set to true in production with SSL)
FORCE_HTTPS=false

# ===========================================
# CORS (allowed origins)
# ===========================================

# ALLOW_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# Rate Limiting
# ===========================================

RATE_LIMIT_PER_MINUTE=60

# ===========================================
# OAuth Providers (optional)
# ===========================================

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# Observability (optional)
# ===========================================

# OpenTelemetry endpoint for distributed tracing
# OTLP_ENDPOINT=http://localhost:4317

# Seed database on startup (disable in production after first run)
SEED_DB_ON_STARTUP=true
